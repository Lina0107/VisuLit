# Copy to .env on VPS before docker compose up

# Required backend
AITUNNEL_API_KEY=replace_with_real_key
AITUNNEL_BASE_URL=https://neuroapi.host/v1/
AITUNNEL_MODEL=gpt-4o-mini

# Domain + SSL (Caddy)
DOMAIN=visulit.com
CADDY_EMAIL=you@example.com

# Optional image generation settings
IMAGE_MODEL=gemini-3-pro-image-preview
IMAGE_SIZE=1024x1536

# Public support email (shown in UI)
NEXT_PUBLIC_SUPPORT_EMAIL=hello@visulit.com

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-2TBVVWWD2S
